#!/bin/sh
set -eu

script="$0"
while [ -L "$script" ]; do
  dir="$(CDPATH= cd -- "$(dirname -- "$script")" && pwd)"
  link="$(readlink "$script")"
  case "$link" in
    /*) script="$link" ;;
    *) script="$dir/$link" ;;
  esac
done

repo_root="$(CDPATH= cd -- "$(dirname -- "$script")/.." && pwd)"
export WHATSAPP_SOURCE_ROOT="${WHATSAPP_SOURCE_ROOT:-$repo_root}"
exec python3 "$repo_root/cli/whatsapp_cli.py" "$@"
